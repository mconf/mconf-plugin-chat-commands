{
    "compilerOptions": {
        "outDir": "./dist-tsc/",
        "rootDir": "./src",
        "noImplicitAny": true,
        "module": "esnext",
        "target": "es2017",
        "lib": ["es2017", "dom"],
        "jsx": "react",
        "allowJs": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true
    },
    "include": ["src/*"],
    "paths": {
        "*": ["node_modules"]
    },
    "exclude": [
        "node_modules"
    ]
}
